# =============================================================================
# Mihraby environment variables
# Copy this file to `.env` and fill in values for local development.
# For production on Railway, set these in the Railway service's Variables tab.
# =============================================================================

# --- App URL (required for PayPal return_url + Next.js metadataBase) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (Railway MySQL plugin provides the connection vars) ---
# DB_CLIENT is parameterized for the later Postgres swap (Hetzner migration).
# Keep 'mysql2' at launch; flip to 'pg' when migrating to Coolify+Postgres.
DB_CLIENT=mysql2
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=mihraby
DB_PORT=3306

# --- Auth ---
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=
# 32-byte base64 key used for AES-256-GCM token encryption
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY=

# --- PayPal (launch-active payment gateway) ---
# Set PAYPAL_ENV=sandbox for soft launch; flip to "live" only after confirming
# the PayPal account is a verified Business account.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox

# --- Playwright (E2E tests) ---
# Must equal NEXT_PUBLIC_APP_URL exactly; PayPal return_url baked into orders
# has to match or the stubbed approve redirect silently misses.
PLAYWRIGHT_BASE_URL=http://localhost:3000

# --- File storage ---
# STORAGE_ENABLED gates all file-storage operations. At US launch it MUST be
# false: the PayPal path never touches storage, and Railway's filesystem is
# ephemeral. Any call to getFileStorage() returns a DisabledStorage stub that
# throws HTTP 503. Flip to 'true' only when R2Storage (post-launch track T3)
# is wired; until then InstaPay uploads are unavailable by design.
STORAGE_ENABLED=false
UPLOADS_DIR=./uploads

# =============================================================================
# Deferred / dormant — DO NOT set at US launch
# =============================================================================

# Paymob (Egypt launch — disabled)
# PAYMOB_API_KEY=
# PAYMOB_INTEGRATION_ID_CARD=
# PAYMOB_INTEGRATION_ID_WALLET=
# PAYMOB_INTEGRATION_ID_KIOSK=
# PAYMOB_IFRAME_ID=
# PAYMOB_HMAC_SECRET=

# Zoom (Phase 5 automation — deferred)
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=
# ZOOM_REDIRECT_URI=

# Cron secret (Phase 6 hold-expiry — deferred)
# CRON_SECRET=
